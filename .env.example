# Optional privacy-friendly analytics. Set this to your deployed website domain
# after creating a site at https://plausible.io/.
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=example.com

# Optional visitor location map (shows a minimalist world map of where visitors
# are viewing from, on the About page's "Visitor Map" section). Self-hosted via
# a small free Cloudflare Worker -- see worker/README.md for deploy steps.
# Leave unset to hide the section entirely.
NEXT_PUBLIC_VISITOR_MAP_API=
